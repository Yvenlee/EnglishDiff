@page "/quiz"
@attribute [Authorize]

@inject QuizService QuizService
@inject NavigationManager NavigationManager

<div class="container py-5">

    <h2 class="text-center mb-4">Quiz</h2>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border"></div>
        </div>
    }
    else if (questions == null || questions.Count == 0)
    {
        <p class="text-center text-muted">No questions available.</p>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <span>Question @(currentIndex + 1) / @questions.Count</span>
                </div>

                <hr />

                <h5 class="mb-3">@CurrentQuestion.Text</h5>

                @foreach (var a in CurrentQuestion.Answers)
                {
                    var isSelected =
                        selectedAnswers.TryGetValue(CurrentQuestion.Id, out var selected)
                        && selected == a.Id;

                    var hasAnswered = answeredQuestions.ContainsKey(CurrentQuestion.Id);

                    var correctAnswerId =
                        correctAnswers.ContainsKey(CurrentQuestion.Id)
                            ? correctAnswers[CurrentQuestion.Id]
                            : -1;

                    string css = "quiz-option";

                    if (hasAnswered)
                    {
                        if (a.Id == correctAnswerId)
                            css += " correct";
                        else if (isSelected)
                            css += " wrong";
                    }

                    <div class="@css">
                        <label class="w-100 p-2 border rounded mb-2">
                            <input type="radio"
                                   name="@($"q_{CurrentQuestion.Id}")"
                                   disabled="@hasAnswered"
                                   checked="@isSelected"
                                   @onchange="async () => await SelectAnswer(CurrentQuestion.Id, a.Id)" />
                            @a.Text
                        </label>
                    </div>
                }

                <div class="mt-3 d-flex justify-content-end">
                    @if (!isSubmitted)
                    {
                        @if (currentIndex < questions.Count - 1)
                        {
                            <button class="btn btn-primary"
                                    disabled="@(!isAnswered)"
                                    @onclick="Next">
                                Next
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success"
                                    disabled="@(!isAnswered)"
                                    @onclick="SubmitQuiz">
                                Finish
                            </button>
                        }
                    }
                </div>
            </div>
        </div>

        @if (result != null)
        {
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h3>Result</h3>
                    <h1 class="text-primary">@result.ScorePercent %</h1>
                    <p>@result.CorrectAnswers / @result.TotalQuestions correct</p>

                    <button class="btn btn-outline-primary" @onclick="Restart">
                        Restart
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<QuestionDto>? questions;
    private int currentIndex = 0;

    private string? category;
    private int? difficulty;

    private string sessionId = "";

    private bool isLoading = true;
    private bool isAnswered = false;
    private bool isSubmitted = false;

    private ScoreResultDto? result;

    private Dictionary<int, int> selectedAnswers = new();
    private Dictionary<int, int> correctAnswers = new();
    private Dictionary<int, bool> answeredQuestions = new();

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("category", out var cat))
            category = string.IsNullOrWhiteSpace(cat) ? null : cat.ToString();

        if (query.TryGetValue("difficulty", out var diff))
            difficulty = int.TryParse(diff, out var d) ? d : null;

        await LoadQuiz();
    }

    private async Task LoadQuiz()
    {
        isLoading = true;
        var quiz = await QuizService.GetQuiz(category, difficulty, 5);
        questions = quiz.Questions;
        sessionId = quiz.SessionId;
        isLoading = false;
    }

    private QuestionDto CurrentQuestion => questions![currentIndex];

    private async Task SelectAnswer(int questionId, int answerId)
    {
        if (answeredQuestions.ContainsKey(questionId)) return;

        selectedAnswers[questionId] = answerId;

        var response = await QuizService.CheckAnswer(questionId, answerId);

        correctAnswers[questionId] = response.CorrectAnswerId;
        answeredQuestions[questionId] = true;

        isAnswered = true;
        await InvokeAsync(StateHasChanged);
    }

    private void Next()
    {
        currentIndex++;
        isAnswered = false;
    }

    private async Task SubmitQuiz()
    {
        isSubmitted = true;

        var payload = questions!.Select(q =>
        {
            selectedAnswers.TryGetValue(q.Id, out var answerId);

            return new SubmitAnswerDto
            {
                QuestionId = q.Id,
                AnswerId = answerId
            };
        }).ToList();

        result = await QuizService.Submit(sessionId, payload);
    }

    private async Task Restart()
    {
        currentIndex = 0;
        selectedAnswers.Clear();
        isAnswered = false;
        isSubmitted = false;
        result = null;

        await LoadQuiz();
    }
}